{
  "name": "@analytics/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "predev": "npm --prefix ../.. --workspace @analytics/shared run build",
    "dev": "tsx watch src/index.ts",
    "prebuild": "npm --prefix ../.. --workspace @analytics/shared run build",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "pretest": "npm --prefix ../.. --workspace @analytics/shared run build",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --pretty false",
    "prisma:generate": "node scripts/run-prisma.mjs generate",
    "prisma:migrate": "node scripts/run-prisma.mjs migrate deploy"
  },
  "dependencies": {
    "@analytics/shared": "file:../../packages/shared",
    "@prisma/client": "^5.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "nanoid": "^5.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "prisma": "^5.15.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "tsx": "^4.15.7",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
